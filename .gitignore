# Model weights & large binaries (keep the scripts that fetch them, not the files)
*.onnx
*.pt
*.pth
*.pb
*.tflite
*.xmodel
!models/.gitkeep
!models/*.py
!models/*.sh

# VitisAI / NPU compilation caches
*_cache/
*cache*/
vaip_config.json
modelcachekey/

# Datasets
data/
datasets/
*.tar
*.tar.gz
*.zip

# Python
__pycache__/
*.pyc
*.pyo
.venv/
venv/
env/
*.egg-info/
.ipynb_checkpoints/

# Results — keep small numbers/plots, ignore heavy media
results/*.mp4
results/*.avi
*.log

# OS / editor cruft
.DS_Store
.vscode/
*.swp
